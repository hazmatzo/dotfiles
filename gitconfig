[init]
	defaultBranch = main

[core]
	autocrlf = input

[color]
	ui = auto

[pull]
	rebase = true

[push]
	default = simple
	autoSetupRemote = true

[fetch]
	prune = true

[diff]
	colorMoved = zebra

[alias]
	# status / inspection
	st = status
	s  = status -sb
	last = log -1 HEAD
	lg = log --oneline --graph --decorate --all

	# branching
	br = branch
	co = checkout
	sw = switch
	new = switch -c

	# committing
	ci = commit
	cm = commit -m
	amend = commit --amend --no-edit
	reword = commit --amend

	# diffing
	df = diff
	dfs = diff --staged

	# remotes
	p = push
	pf = push --force-with-lease
	pushf = push --force-with-lease
	sync = !git pull --rebase && git push

	# rebase current branch on the latest origin/main (or a base branch you pass in)
	# usage:  git update          # rebases on origin/main
	#         git update master   # rebases on origin/master
	update = "!f() { base=\"${1:-main}\"; git fetch origin \"$base\" && git rebase \"origin/$base\"; }; f"

	# undo
	unstage = reset HEAD --
	undo = reset --soft HEAD~1
